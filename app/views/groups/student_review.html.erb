<div class="glass-card wide mb-4">
  <div class="flex justify-between items-center mb-4 border-bottom" style="border-bottom: 1px solid var(--glass-border); padding-bottom: 1rem;">
    <div>
      <h2 style="margin: 0;">Submission Details: <%= @student.name %></h2>
      <p style="color: var(--text-muted); font-size: 0.9rem; margin: 0.5rem 0 0 0;"><%= @course.course_code %> - Group <%= @group.id %></p>
    </div>
    <%= link_to "Back to Group", course_group_path(@course, @group), class: "btn btn-secondary" %>
  </div>

  <h3 style="margin-bottom: 1rem;">Part 1: Self Assessment</h3>
  <div style="background: rgba(15, 23, 42, 0.4); border: 1px solid var(--glass-border); border-radius: var(--br-md); padding: 1.5rem; margin-bottom: 2rem;">
    <% if @self_assessments.empty? %>
      <p style="color: var(--text-muted); font-style: italic;">No self assessment answers submitted.</p>
    <% else %>
      <% @self_assessments.each_with_index do |sa, index| %>
        <div class="form-group" style="<%= 'margin-bottom: 1.5rem;' unless index == @self_assessments.length - 1 %>">
          <label style="display: block; font-weight: 500; margin-bottom: 0.5rem; color: var(--accent-color);"><%= index + 1 %>. <%= sa.question_text %></label>
          <div style="background: rgba(255,255,255,0.05); padding: 1rem; border-radius: var(--br-sm); white-space: pre-wrap; font-size: 0.95rem;">
            <%= sa.answer.presence || "No answer provided." %>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>

  <h3 style="margin-bottom: 1rem;">Part 2: Peer Evaluations Given</h3>
  <% if @peer_reviews_given.empty? %>
    <p style="color: var(--text-muted); font-style: italic;">No peer evaluations submitted.</p>
  <% else %>
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1rem;">
      <% @peer_reviews_given.each do |review| %>
        <div style="background: rgba(15, 23, 42, 0.4); border: 1px solid var(--glass-border); border-radius: var(--br-md); padding: 1.25rem;">
          <h4 style="margin-top: 0; margin-bottom: 0.5rem; color: var(--accent-color);"><%= review.reviewee.name %></h4>
          
          <div style="margin-bottom: 0.5rem;">
            <span style="font-weight: 500;">Raw Score Given:</span> 
            <span style="color: var(--text-light);"><%= review.score %></span>
          </div>
          
          <div style="margin-bottom: 0.5rem;">
            <span style="font-weight: 500;">Adjusted Score (AdjR):</span> 
            <span style="color: var(--text-light);"><%= review.score %></span>
            <!-- Note: review.score is currently saved as the adjusted score by the calculator in the submit action -->
          </div>

          <div style="margin-top: 1rem;">
            <div style="font-weight: 500; margin-bottom: 0.25rem; font-size: 0.9rem;">Comments:</div>
            <div style="background: rgba(255,255,255,0.05); padding: 0.75rem; border-radius: var(--br-sm); font-size: 0.85rem; font-style: italic;">
              "<%= review.comment.presence || "No comments." %>"
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

</div>
