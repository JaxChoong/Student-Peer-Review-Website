<style>
  .member-tab {
    padding: 1rem;
    border-bottom: 1px solid var(--glass-border);
    cursor: pointer;
    transition: background 0.2s, border-left 0.2s;
    border-left: 3px solid transparent;
  }
  .member-tab:hover {
    background: rgba(255,255,255,0.05);
  }
  .member-tab.active {
    background: rgba(255,255,255,0.1);
    border-left: 3px solid var(--accent-color);
  }
  .review-pane {
    display: none;
  }
  .review-pane.active {
    display: block;
    animation: fadeIn 0.3s ease-out;
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(5px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<div class="glass-card wide mb-4">
  <div class="flex justify-between items-center mb-4 border-bottom" style="border-bottom: 1px solid var(--glass-border); padding-bottom: 1rem;">
    <div>
      <h2 style="margin: 0;">Group <%= @group.id %></h2>
      <p style="color: var(--text-muted); font-size: 0.9rem; margin: 0.5rem 0 0 0;"><%= @course.course_code %> - <%= @course.course_name %></p>
    </div>
    <%= link_to "Back to Groups", course_groups_path(@course), class: "btn btn-secondary" %>
  </div>

  <div style="display: flex; gap: 2rem; align-items: flex-start; flex-wrap: wrap;">
    <!-- Left Column: Member List -->
    <div style="flex: 0 0 300px; width: 100%; background: rgba(15, 23, 42, 0.4); border: 1px solid var(--glass-border); border-radius: var(--br-md); overflow: hidden;">
      <h3 style="padding: 1rem; margin: 0; border-bottom: 1px solid var(--glass-border); background: rgba(255,255,255,0.02);">Members</h3>
      <ul id="member-tabs" style="list-style: none; padding: 0; margin: 0;">
        <% first_submitted_member = @group.members.find { |m| @self_assessments[m.id].present? || @peer_reviews_given[m.id].present? } || @group.members.first %>
        
        <% @group.members.each do |member| %>
          <li class="member-tab <%= 'active' if member == first_submitted_member %>" data-target="review-<%= member.id %>">
            <div style="font-weight: 500;"><%= member.name %></div>
            <div style="font-size: 0.85rem; color: var(--text-muted);"><%= member.email %></div>
            <% if @self_assessments[member.id].present? || @peer_reviews_given[member.id].present? %>
              <div style="font-size: 0.75rem; color: var(--success-color); margin-top: 0.25rem;">✓ Submitted</div>
            <% else %>
              <div style="font-size: 0.75rem; color: var(--text-muted); margin-top: 0.25rem; font-style: italic;">Pending</div>
            <% end %>
          </li>
        <% end %>
      </ul>
    </div>

    <!-- Right Column: Review Content Pane -->
    <div style="flex: 1; min-width: 300px; background: rgba(15, 23, 42, 0.4); border: 1px solid var(--glass-border); border-radius: var(--br-md); padding: 1.5rem; min-height: 500px;">
      <% @group.members.each do |member| %>
        <div id="review-<%= member.id %>" class="review-pane <%= 'active' if member == first_submitted_member %>">
          <h3 style="margin-top: 0; margin-bottom: 1.5rem; color: var(--accent-color); border-bottom: 1px solid var(--glass-border); padding-bottom: 0.5rem;">
            Submission Details: <%= member.name %>
          </h3>
          
          <% self_assessments = @self_assessments[member.id] || [] %>
          <% peer_reviews = @peer_reviews_given[member.id] || [] %>

          <% if self_assessments.empty? && peer_reviews.empty? %>
            <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; height: 300px; color: var(--text-muted);">
              <svg style="width: 48px; height: 48px; margin-bottom: 1rem; opacity: 0.5;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
              <p>This student has not submitted their peer review yet.</p>
            </div>
          <% else %>
            <h4 style="margin-bottom: 1rem;">Part 1: Self Assessment</h4>
            <div style="margin-bottom: 2rem;">
              <% if self_assessments.empty? %>
                <p style="color: var(--text-muted); font-style: italic; font-size: 0.9rem;">No self assessment answers submitted.</p>
              <% else %>
                <% self_assessments.each_with_index do |sa, index| %>
                  <div style="margin-bottom: 1.25rem;">
                    <div style="font-weight: 500; margin-bottom: 0.5rem; font-size: 0.95rem;"><%= index + 1 %>. <%= sa.question_text %></div>
                    <div style="background: rgba(255,255,255,0.03); padding: 0.75rem 1rem; border-radius: var(--br-sm); white-space: pre-wrap; font-size: 0.9rem; color: var(--text-light); border-left: 2px solid var(--accent-color);">
                      <%= sa.answer.presence || "No answer provided." %>
                    </div>
                  </div>
                <% end %>
              <% end %>
            </div>

            <h4 style="margin-bottom: 1rem;">Part 2: Peer Evaluations Given</h4>
            <% if peer_reviews.empty? %>
              <p style="color: var(--text-muted); font-style: italic; font-size: 0.9rem;">No peer evaluations submitted.</p>
            <% else %>
              <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 1rem;">
                <% peer_reviews.each do |review| %>
                  <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); border-radius: var(--br-md); padding: 1rem;">
                    <div style="font-weight: 500; margin-bottom: 0.5rem; color: var(--accent-color);"><%= review.reviewee.name %></div>
                    
                    <div style="font-size: 0.85rem; margin-bottom: 0.25rem;">
                      <span style="color: var(--text-muted);">Score Given:</span> 
                      <span><%= review.score %></span>
                    </div>
                    
                    <div style="font-size: 0.85rem; margin-top: 0.75rem;">
                      <div style="color: var(--text-muted); margin-bottom: 0.25rem;">Comments:</div>
                      <div style="font-style: italic; color: var(--text-light);">
                        "<%= review.comment.presence || "No comments." %>"
                      </div>
                    </div>
                  </div>
                <% end %>
              </div>
            <% end %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<script>
  document.addEventListener('turbo:load', function() {
    setupTabs();
  });
  
  document.addEventListener('DOMContentLoaded', function() {
    setupTabs();
  });

  function setupTabs() {
    const tabs = document.querySelectorAll('.member-tab');
    const panes = document.querySelectorAll('.review-pane');

    if (tabs.length === 0) return;

    tabs.forEach(tab => {
      // Remove old listeners to prevent duplicates if Turbo loads twice
      tab.replaceWith(tab.cloneNode(true));
    });

    const newTabs = document.querySelectorAll('.member-tab');
    
    newTabs.forEach(tab => {
      tab.addEventListener('click', () => {
        newTabs.forEach(t => t.classList.remove('active'));
        panes.forEach(p => p.classList.remove('active'));

        tab.classList.add('active');
        const targetId = tab.getAttribute('data-target');
        const targetPane = document.getElementById(targetId);
        if (targetPane) {
          targetPane.classList.add('active');
        }
      });
    });
  }
</script>
