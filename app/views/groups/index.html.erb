<section class="mb-20">
  <div
    class="
      mb-8 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between
    "
  >
    <div>
      <h2 class="text-2xl font-bold tracking-tight text-slate-900"><%= @course.course_code %>
        - Manage Groups</h2>
      <p class="mt-1 text-sm text-slate-500"><%= @course.course_name %></p>
    </div>

    <div class="flex flex-wrap items-center gap-2">
      <%= link_to "Preview Student Form",
      preview_layout_path(course_id: @course.id),
      class:
        "inline-flex items-center gap-2 rounded-lg border border-slate-200 bg-white px-3.5 py-2 text-sm font-semibold text-slate-700 shadow-sm transition-colors hover:bg-slate-50 focus:outline-none focus-visible:ring-2 focus-visible:ring-slate-400 focus-visible:ring-offset-2" %>
      <%= link_to course_marks_path(@course), class: "inline-flex items-center gap-2 rounded-lg bg-blue-600 px-3.5 py-2 text-sm font-semibold text-white shadow-sm transition-all duration-200 hover:bg-blue-700 focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-600 focus-visible:ring-offset-2" do %>
        <svg
          class="h-4 w-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
          />
        </svg>
        Final Marks
      <% end %>
      <%= link_to "Back to Dashboard",
      dashboard_path,
      class:
        "inline-flex items-center gap-2 rounded-lg border border-slate-200 bg-white px-3.5 py-2 text-sm font-semibold text-slate-700 shadow-sm transition-colors hover:bg-slate-50 focus:outline-none focus-visible:ring-2 focus-visible:ring-slate-400 focus-visible:ring-offset-2" %>
    </div>
  </div>

  <% if @course.pending_credentials_csv.present? %>
    <div class="mb-8 rounded-xl border border-blue-200 bg-blue-50 p-6 shadow-sm">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
        <div>
          <h3 class="text-lg font-bold text-blue-900">Student Accounts Created</h3>
          <p class="text-sm text-blue-700 mt-1">Temporary passwords have been generated for the new students.
            Please download the credentials CSV now and distribute it to your
            students. This button will disappear once downloaded.</p>
        </div>
        <div>
          <%= link_to "Download Credentials CSV",
          download_credentials_course_path(@course),
          class:
            "inline-flex items-center justify-center gap-2 rounded-lg bg-blue-600 px-6 py-3 text-sm font-semibold text-white shadow-sm transition-all duration-200 hover:bg-blue-700 hover:-translate-y-0.5 focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-600 focus-visible:ring-offset-2",
          data: {
            turbo: false,
          } %>
        </div>
      </div>
    </div>
  <% end %>

  <div
    class="
      mb-8 overflow-hidden rounded-2xl border border-white/60 bg-white/60
      backdrop-blur-xl shadow-lg
    "
  >
    <div class="border-b border-white/40 bg-white/40 px-6 py-4">
      <h3 class="text-lg font-bold tracking-tight text-slate-900">Course Settings</h3>
    </div>

    <div class="px-6 py-6 space-y-8">
      <!-- Top Row: Dates & Mode Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Global Review Dates -->
        <div>
          <h4 class="mb-3 text-sm font-semibold uppercase tracking-wider text-slate-500">Set Global Review Dates</h4>
          <%= form_with url: update_review_dates_course_path(@course), method: :patch, local: true do |f| %>
            <div class="flex flex-col sm:flex-row items-end gap-3">
              <div class="w-full">
                <%= f.label :start_date,
                        "Open Date",
                        class: "mb-1.5 block text-sm font-medium text-slate-700" %>
                <%= f.date_field :start_date,
                             value: @course.start_date,
                             class:
                               "w-full rounded-lg border border-slate-200 bg-white py-2 px-3 text-sm font-medium text-slate-900 shadow-sm transition-colors hover:border-slate-300 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/30",
                             required: true %>
              </div>
              <div class="w-full">
                <%= f.label :end_date,
                        "Close Date",
                        class: "mb-1.5 block text-sm font-medium text-slate-700" %>
                <%= f.date_field :end_date,
                             value: @course.end_date,
                             class:
                               "w-full rounded-lg border border-slate-200 bg-white py-2 px-3 text-sm font-medium text-slate-900 shadow-sm transition-colors hover:border-slate-300 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/30",
                             required: true %>
              </div>
              <%= f.submit "Update All",
                       class:
                         "inline-flex w-full sm:w-auto items-center justify-center gap-2 rounded-lg bg-blue-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition-all duration-200 hover:bg-blue-700 focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-600 focus-visible:ring-offset-2 cursor-pointer" %>
            </div>
          <% end %>
        </div>
        <!-- Course Introduction -->
        <div>
          <h4 class="mb-3 text-sm font-semibold uppercase tracking-wider text-slate-500">Course Introduction</h4>
          <%= form_with url: update_intro_course_path(@course), method: :patch, local: true do |f| %>
            <div class="flex flex-col sm:flex-row items-end gap-4">
              <div class="w-full">
                <%= f.text_area :content,
                            value: @course.introduction&.content,
                            class:
                              "w-full resize-y rounded-lg border border-slate-200 bg-white px-3.5 py-2.5 text-sm text-slate-900 shadow-sm transition-colors hover:border-slate-300 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/30",
                            required: true,
                            rows: 2,
                            placeholder: "Welcome to..." %>
              </div>
              <%= f.submit "Save Intro",
                       class:
                         "inline-flex w-full sm:w-auto items-center justify-center gap-2 rounded-lg border border-slate-200 bg-white px-5 py-3 text-sm font-semibold text-slate-700 shadow-sm transition-colors hover:bg-slate-50 focus:outline-none focus-visible:ring-2 focus-visible:ring-slate-400 focus-visible:ring-offset-2 cursor-pointer shrink-0" %>
            </div>
          <% end %>
        </div>
        <!-- Course Scoring Scheme -->
        <div>
          <h4 class="mb-3 text-sm font-semibold uppercase tracking-wider text-slate-500">Scoring Scheme</h4>
          <% if @course.review_started? %>
            <div class="rounded-lg bg-slate-100/80 p-4 border border-slate-200">
              <div class="flex items-center gap-2 mb-1.5">
                <span
                  class="
                    inline-flex items-center rounded-md bg-blue-50 px-2.5 py-1 text-xs font-bold
                    text-blue-700 ring-1 ring-inset ring-blue-700/10
                  "
                >
                  <%= @course.scoring_scheme.titleize %>
                </span>
                <span
                  class="
                    inline-flex items-center gap-1 text-[11px] font-semibold text-slate-500
                  "
                >
                  <svg
                    class="h-3.5 w-3.5 text-slate-400"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  ><path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2.5"
                      d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"
                    /></svg>
                  Locked
                </span>
              </div>
              <p class="text-[11px] leading-normal text-slate-500">
                Scoring scheme is locked because the review period has started
                or evaluations have already been submitted.
              </p>
            </div>
          <% else %>
            <%= form_with url: update_scoring_scheme_course_path(@course), method: :patch, local: true do |f| %>
              <div class="flex flex-col sm:flex-row items-end gap-3">
                <div class="w-full">
                  <%= f.label :scoring_scheme,
                          "Select Scheme",
                          class: "mb-1.5 block text-sm font-medium text-slate-700" %>
                  <%= f.select :scoring_scheme,
                           [["Numeric (1-5 rating)", 0], ["Rubric (custom matrix)", 1]],
                           { selected: @course.read_attribute_before_type_cast(:scoring_scheme) },
                           class:
                             "w-full rounded-lg border border-slate-200 bg-white py-2 px-3 text-sm font-medium text-slate-900 shadow-sm transition-colors hover:border-slate-300 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/30" %>
                </div>
                <%= f.submit "Save Scheme",
                         class:
                           "inline-flex w-full sm:w-auto items-center justify-center gap-2 rounded-lg border border-slate-200 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 shadow-sm transition-colors hover:bg-slate-50 focus:outline-none focus-visible:ring-2 focus-visible:ring-slate-400 focus-visible:ring-offset-2 cursor-pointer" %>
              </div>
            <% end %>
          <% end %>
        </div>
        <!-- Course Review Mode -->
        <div>
          <h4 class="mb-3 text-sm font-semibold uppercase tracking-wider text-slate-500">Course Review Mode</h4>
          <% if @course.review_started? %>
            <div class="rounded-lg bg-slate-100/80 p-4 border border-slate-200">
              <div class="flex items-center gap-2 mb-1.5">
                <span
                  class="
                    inline-flex items-center rounded-md bg-blue-50 px-2.5 py-1 text-xs font-bold
                    text-blue-700 ring-1 ring-inset ring-blue-700/10
                  "
                >
                  <%= @course.review_mode.titleize %>
                  Mode
                </span>
                <span
                  class="
                    inline-flex items-center gap-1 text-[11px] font-semibold text-slate-500
                  "
                >
                  <svg
                    class="h-3.5 w-3.5 text-slate-400"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  ><path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2.5"
                      d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"
                    /></svg>
                  Locked
                </span>
              </div>
              <p class="text-[11px] leading-normal text-slate-500">
                Review mode is locked because the review period has started or
                evaluations have already been submitted.
              </p>
            </div>
          <% else %>
            <%= form_with url: update_review_mode_course_path(@course), method: :patch, local: true do |f| %>
              <div class="flex flex-col sm:flex-row items-end gap-3">
                <div class="w-full">
                  <%= f.label :review_mode,
                          "Select Mode",
                          class: "mb-1.5 block text-sm font-medium text-slate-700" %>
                  <%= f.select :review_mode,
                           [["Peer Ratings Only Mode", 0], ["Hybrid Mode", 1]],
                           { selected: @course.read_attribute_before_type_cast(:review_mode) },
                           class:
                             "w-full rounded-lg border border-slate-200 bg-white py-2 px-3 text-sm font-medium text-slate-900 shadow-sm transition-colors hover:border-slate-300 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/30" %>
                </div>
                <%= f.submit "Save Mode",
                         class:
                           "inline-flex w-full sm:w-auto items-center justify-center gap-2 rounded-lg border border-slate-200 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 shadow-sm transition-colors hover:bg-slate-50 focus:outline-none focus-visible:ring-2 focus-visible:ring-slate-400 focus-visible:ring-offset-2 cursor-pointer" %>
              </div>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <h3 class="mb-6 text-xl font-bold tracking-tight text-slate-900">Sections & Groups</h3>

  <% @sections.each do |section| %>
    <div
      class="
        mb-8 overflow-hidden rounded-2xl border border-white/60 bg-white/60
        backdrop-blur-xl shadow-lg
      "
    >
      <!-- Section Header -->
      <div
        class="
          flex flex-col sm:flex-row sm:items-center justify-between border-b
          border-white/40 bg-white/40 px-6 py-4 gap-4
        "
      >
        <h3 class="text-lg font-bold tracking-tight text-blue-600">Section:
          <%= section.section_code %></h3>

        <%= form_with url: update_review_dates_section_path(section), method: :patch, local: true, class: "flex flex-wrap items-center gap-2" do |f| %>
          <span class="text-sm font-medium text-slate-500">Dates:</span>
          <%= f.date_field :start_date,
                       value: section.start_date,
                       class:
                         "rounded-md border border-slate-200 bg-white py-1.5 px-2 text-xs font-medium text-slate-900 shadow-sm focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/30" %>
          <span class="text-slate-400">-</span>
          <%= f.date_field :end_date,
                       value: section.end_date,
                       class:
                         "rounded-md border border-slate-200 bg-white py-1.5 px-2 text-xs font-medium text-slate-900 shadow-sm focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/30" %>
          <%= f.submit "Save",
                   class:
                     "rounded-md bg-slate-100 px-3 py-1.5 text-xs font-semibold text-slate-600 transition-colors hover:bg-slate-200 cursor-pointer" %>
        <% end %>
      </div>
      <!-- Groups Grid -->
      <div class="p-6">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          <% section.groups.each do |group| %>
            <div
              class="
                group relative flex flex-col rounded-xl border border-white/60 bg-white/60
                backdrop-blur-md p-4 shadow-sm transition-all duration-200 hover:border-white/80
                hover:shadow-md hover:bg-white/80
              "
            >
              <div class="mb-3 flex items-start justify-between">
                <h4 class="font-bold tracking-tight text-slate-900"><%= group.group_name %></h4>
                <%= link_to "View Details →",
                course_group_path(@course, group),
                class: "text-xs font-semibold text-blue-600 hover:text-blue-700" %>
              </div>

              <ul class="flex flex-col gap-1.5">
                <% group.members.each do |member| %>
                  <li class="flex items-center gap-2 text-sm text-slate-600">
                    <% has_submitted = @submitted_reviewer_ids.include?(member.id) %>
                    <span
                      class="
                        h-1.5 w-1.5 rounded-full <%= has_submitted ? 'bg-emerald-500' : 'bg-slate-300' %>
                      "
                    ></span>
                    <%= member.name %>
                  </li>
                <% end %>
                <% if group.members.empty? %>
                  <li class="text-sm text-slate-400 italic">No members</li>
                <% end %>
              </ul>
            </div>
          <% end %>
          <% if section.groups.empty? %>
            <div
              class="
                col-span-full rounded-xl border border-dashed border-slate-300 bg-slate-50 p-6
                text-center
              "
            >
              <p class="text-sm text-slate-500">No groups in this section.</p>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

</section>
