<!-- =========================================================
     2. COURSE DASHBOARD — CARD GRID
========================================================== -->
<section class="mb-20">
  <div class="mb-8 flex flex-col gap-1 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <h1 class="text-2xl font-bold tracking-tight text-slate-900 text-balance">Your Courses</h1>
      <p class="mt-1 text-sm text-slate-500">Manage sections, groups, and peer reviews across your active courses.</p>
    </div>
    
    <% if current_user.lecturer? %>
      <a href="<%= new_course_path %>" class="mt-4 inline-flex items-center gap-2 rounded-lg bg-blue-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm shadow-blue-600/30 transition-all duration-200 hover:bg-blue-700 hover:shadow-md hover:shadow-blue-600/30 focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-600 focus-visible:ring-offset-2 sm:mt-0">
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
        New Course
      </a>
    <% end %>
  </div>

  <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
    <% @courses.each do |course| %>
      <article class="group relative flex flex-col rounded-2xl border border-white/60 bg-white/60 backdrop-blur-xl p-6 shadow-lg transition-all duration-300 hover:-translate-y-1 hover:border-white/80 hover:shadow-xl hover:bg-white/70">
        <div class="mb-4 flex items-start justify-between">
          <span class="inline-flex items-center rounded-md bg-blue-50 px-2.5 py-1 text-xs font-bold tracking-wide text-blue-700 ring-1 ring-inset ring-blue-600/20"><%= course.course_code %></span>
          
          <% if course.end_date && course.end_date < Date.today %>
            <span class="inline-flex items-center gap-1.5 rounded-full bg-slate-100 px-2.5 py-1 text-xs font-semibold text-slate-600">
              <span class="h-1.5 w-1.5 rounded-full bg-slate-400"></span>Closed
            </span>
          <% else %>
            <span class="inline-flex items-center gap-1.5 rounded-full bg-emerald-50 px-2.5 py-1 text-xs font-semibold text-emerald-700">
              <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span>Active
            </span>
          <% end %>
        </div>
        
        <h3 class="text-lg font-semibold tracking-tight text-slate-900"><%= course.course_name %></h3>
        <p class="mt-1 text-sm text-slate-500 line-clamp-2"><%= course.introduction&.content || "No description provided." %></p>

        <div class="my-5 grid grid-cols-2 gap-3">
          <div class="rounded-xl bg-slate-50 px-3 py-2.5 ring-1 ring-inset ring-slate-100">
            <p class="text-xl font-bold tracking-tight text-slate-900"><%= course.sections.count %></p>
            <p class="text-xs font-medium text-slate-500">Sections</p>
          </div>
          <div class="rounded-xl bg-slate-50 px-3 py-2.5 ring-1 ring-inset ring-slate-100">
            <p class="text-xl font-bold tracking-tight text-slate-900"><%= course.groups.count %></p>
            <p class="text-xs font-medium text-slate-500">Groups</p>
          </div>
        </div>

        <div class="mt-auto flex items-center gap-2.5">
          <% if current_user.lecturer? %>
            <a href="<%= course_marks_path(course) %>" class="flex-1 rounded-lg bg-blue-600 px-4 py-2.5 text-center text-sm font-semibold text-white shadow-sm transition-all duration-200 hover:bg-blue-700 focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-600 focus-visible:ring-offset-2">Marks & Reports</a>
            <a href="<%= course_groups_path(course) %>" class="rounded-lg border border-slate-200 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 transition-colors hover:bg-slate-50 focus:outline-none focus-visible:ring-2 focus-visible:ring-slate-400 focus-visible:ring-offset-2">Manage</a>
          <% else %>
            <% if Review.exists?(reviewer: current_user, course: course) || SelfAssessment.exists?(user: current_user, course: course) %>
              <button class="flex-1 rounded-lg bg-slate-100 px-4 py-2.5 text-sm font-semibold text-slate-400 cursor-not-allowed" disabled>Review Submitted ✓</button>
            <% else %>
              <a href="<%= course_peer_reviews_start_path(course) %>" class="flex-1 rounded-lg bg-blue-600 px-4 py-2.5 text-center text-sm font-semibold text-white shadow-sm transition-all duration-200 hover:bg-blue-700 focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-600 focus-visible:ring-offset-2">Peer Review</a>
            <% end %>
          <% end %>
        </div>
      </article>
    <% end %>

    <% if @courses.empty? %>
      <div class="col-span-full rounded-2xl border border-dashed border-white/60 bg-white/40 backdrop-blur-md p-12 text-center shadow-sm">
        <svg class="mx-auto h-12 w-12 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
        </svg>
        <h3 class="mt-2 text-sm font-semibold text-slate-900">No courses</h3>
        <p class="mt-1 text-sm text-slate-500">You are not currently enrolled in any active courses.</p>
      </div>
    <% end %>
  </div>
</section>
