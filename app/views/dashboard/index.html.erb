<div class="dashboard-header mb-4 flex justify-between items-center">
  <div>
    <h2>Dashboard</h2>
    <p style="color: var(--text-muted); font-size: 0.9rem;">Welcome back, <%= current_user.name %>! (<%= current_user.role.capitalize %>)</p>
  </div>
  <div class="flex" style="gap: 1rem;">
    <% if current_user.lecturer? %>
      <%= link_to "+ New Course", new_course_path, class: "btn btn-primary" %>
    <% end %>
    <%= button_to "Log Out", logout_path, method: :delete, class: "btn btn-secondary" %>
  </div>
</div>

<div class="courses-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.5rem;">
  <% if @courses.empty? %>
    <div class="glass-card wide" style="grid-column: 1 / -1; text-align: center;">
      <p style="color: var(--text-muted);">You don't have any courses yet.</p>
    </div>
  <% else %>
    <% @courses.each do |course| %>
      <div class="glass-card" style="padding: 1.5rem; transition: transform var(--transition-fast);">
        <h3 style="margin-bottom: 0.5rem;"><%= course.course_code %></h3>
        <p style="color: var(--text-muted); margin-bottom: 1rem; font-size: 0.9rem;"><%= course.course_name %></p>
        
        <div class="stats flex justify-between" style="border-top: 1px solid var(--glass-border); padding-top: 1rem; margin-bottom: 1.5rem; font-size: 0.85rem;">
          <div>
            <strong style="color: var(--accent-color); display: block;"><%= course.sections.count %></strong>
            <span style="color: var(--text-muted);">Sections</span>
          </div>
          <div>
            <strong style="color: var(--accent-color); display: block;"><%= course.groups.count %></strong>
            <span style="color: var(--text-muted);">Groups</span>
          </div>
          <% if current_user.lecturer? %>
            <div>
              <strong style="color: var(--accent-color); display: block;"><%= course.students.count %></strong>
              <span style="color: var(--text-muted);">Students</span>
            </div>
          <% end %>
        </div>

        <div class="actions flex" style="gap: 0.5rem;">
          <% if current_user.lecturer? %>
            <%= link_to "Manage Groups", course_groups_path(course), class: "btn btn-secondary", style: "flex: 1; padding: 0.5rem; font-size: 0.85rem;" %>
            <%= button_to "Delete", course_path(course), method: :delete, class: "btn btn-secondary", style: "color: var(--danger-color); padding: 0.5rem; font-size: 0.85rem;", form: { data: { turbo_confirm: 'Are you sure you want to delete this course and all its data?' } } %>
          <% else %>
            <%= link_to "Peer Review", course_peer_reviews_start_path(course), class: "btn btn-primary", style: "flex: 1; padding: 0.5rem; font-size: 0.85rem;" %>
          <% end %>
        </div>
      </div>
    <% end %>
  <% end %>
</div>
