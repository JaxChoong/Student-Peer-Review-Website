<div class="rubric-table-wrapper overflow-x-auto rounded-lg border border-slate-200 shadow-sm">
  <table class="rubric-matrix w-full text-left border-collapse" style="--col-count: <%= template.rubric_criteria.map { |c| c.rubric_columns.size }.max || 4 %>">
    <thead>
      <tr class="bg-slate-50">
        <th class="criteria-label-header p-3 border-b border-r border-slate-200 font-semibold text-sm text-slate-700 w-1/4">Criteria</th>
        <th class="p-3 border-b border-slate-200 font-semibold text-sm text-slate-700 text-center" colspan="10">Rating Options</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-200">
      <% template.rubric_criteria.each do |criteria| %>
        <tr class="bg-white">
          <td class="criteria-label p-3 border-r border-slate-200 align-top">
            <div class="font-medium text-slate-900"><%= criteria.label %></div>
          </td>
          <td class="p-3 max-w-0" colspan="10">
            <div class="flex gap-3 overflow-x-auto pb-2">
              <% criteria.rubric_columns.each do |col| %>
                <div class="rubric-cell shrink-0 w-48 border border-slate-200 rounded-md p-3 bg-slate-50 pointer-events-none">
                  <strong class="block mb-2 text-lg font-bold text-blue-700"><%= col.weight %> pts</strong>
                  <% if col.descriptions.any? %>
                    <div class="rubric-md-desc md-prose-xs"
                         data-raw="<%= ERB::Util.html_escape(col.descriptions.join("\n")) %>"></div>
                  <% end %>
                </div>
              <% end %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
<script>
  document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.rubric-md-desc[data-raw]').forEach(function(el) {
      if (typeof marked !== 'undefined') {
        el.innerHTML = marked.parse(el.dataset.raw)
      } else {
        el.textContent = el.dataset.raw
      }
    })
  })
</script>
