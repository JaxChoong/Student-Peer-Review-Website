<!-- =========================================================
     3. PEER REVIEW FORM
========================================================== -->
<section class="mb-20">
  <div class="mx-auto max-w-3xl">
    
    <div class="mb-6">
      <%= link_to dashboard_path, class: "inline-flex items-center gap-2 rounded-lg border border-slate-200 bg-white px-3.5 py-2 text-sm font-semibold text-slate-700 shadow-sm transition-colors hover:bg-slate-50 focus:outline-none focus-visible:ring-2 focus-visible:ring-slate-400 focus-visible:ring-offset-2" do %>
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
        Back to Dashboard
      <% end %>
    </div>

    <div class="overflow-hidden rounded-2xl border border-white/60 bg-white/60 backdrop-blur-xl shadow-lg">
      <!-- Form header -->
      <div class="border-b border-white/40 bg-white/40 px-6 py-5 sm:px-8">
        <h2 class="text-lg font-bold tracking-tight text-slate-900">Peer Evaluation</h2>
        <p class="mt-1 text-sm text-slate-500">
          <span class="font-semibold text-slate-700"><%= current_user.name %></span> &middot; Group <%= @group.id %> &middot; <%= @course.course_code %>
        </p>
      </div>

      <%= form_with url: course_peer_reviews_submit_path(@course), local: true, class: "px-6 py-7 sm:px-8" do |f| %>

        <!-- Part 1: Self Assessment -->
        <fieldset class="mb-8">
          <legend class="mb-1 text-sm font-semibold uppercase tracking-wider text-slate-400">Part 1: Self Assessment</legend>
          <p class="mb-5 text-sm text-slate-500">Reflect on your own contributions to the group.</p>

          <div class="space-y-5">
            <% @course.question_layout.questions.each_with_index do |question, index| %>
              <div>
                <label class="mb-1.5 block text-sm font-medium text-slate-700">
                  <%= index + 1 %>. <%= question.question_text %>
                </label>
                <%= f.text_area "answers[#{question.id}]", rows: 3, required: true, minlength: 30, class: "w-full resize-none rounded-lg border border-slate-200 bg-white px-3.5 py-3 text-sm text-slate-900 shadow-sm transition-colors hover:border-slate-300 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/30" %>
              </div>
            <% end %>
            <% if @course.question_layout.questions.empty? %>
              <p class="text-sm text-slate-400 italic">No self assessment questions configured for this course.</p>
            <% end %>
          </div>
        </fieldset>

        <div class="my-7 h-px w-full bg-slate-100"></div>

        <!-- Part 2: Peer Evaluation -->
        <fieldset class="mb-2">
          <legend class="mb-5 text-sm font-semibold uppercase tracking-wider text-slate-400">Part 2: Peer Ratings</legend>
          <p class="mb-5 text-sm text-slate-500">Evaluate each of your group members. Score out of <%= @group.members.count * 3 %>.</p>

          <div class="space-y-8">
            <% @teammates.each do |teammate| %>
              <div class="rounded-xl border border-white/60 bg-white/60 backdrop-blur-md p-5 shadow-sm">
                <div class="mb-4 flex items-center gap-3">
                  <span class="flex h-8 w-8 items-center justify-center rounded-full bg-blue-100 text-xs font-bold text-blue-700">
                    <%= teammate.name.split.map(&:first).join.upcase.slice(0, 2) %>
                  </span>
                  <span class="font-semibold text-slate-900"><%= teammate.name %></span>
                </div>

                <div class="space-y-4">
                  <!-- Rating -->
                  <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
                    <label class="text-sm font-medium text-slate-700">Overall Contribution Rating</label>
                    <div class="relative w-full sm:w-44">
                      <%= f.number_field "reviews[#{teammate.id}][score]", min: 0, max: @group.members.count * 3, required: true, class: "w-full rounded-lg border border-slate-200 bg-white py-2.5 px-3.5 text-sm font-medium text-slate-900 shadow-sm transition-colors hover:border-slate-300 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/30" %>
                    </div>
                  </div>

                  <!-- Comment -->
                  <div>
                    <label class="mb-1.5 block text-sm font-medium text-slate-700">Constructive Feedback</label>
                    <%= f.text_area "reviews[#{teammate.id}][comment]", rows: 2, required: true, minlength: 30, placeholder: "What did they do well? How could they improve?", class: "w-full resize-none rounded-lg border border-slate-200 bg-white px-3.5 py-3 text-sm text-slate-900 placeholder:text-slate-400 shadow-sm transition-colors hover:border-slate-300 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/30" %>
                  </div>
                </div>
              </div>
            <% end %>
            <% if @teammates.empty? %>
              <p class="text-sm text-slate-400 italic">You are the only member in this group.</p>
            <% end %>
          </div>
        </fieldset>

        <!-- Actions -->
        <div class="mt-8 flex items-center justify-end gap-3">
          <button type="submit" class="inline-flex items-center gap-2 rounded-lg bg-blue-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm shadow-blue-600/30 transition-all duration-200 hover:bg-blue-700 hover:shadow-md hover:shadow-blue-600/40 active:scale-[0.98] focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-600 focus-visible:ring-offset-2">
            Submit Final Review
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </button>
        </div>
      <% end %>
    </div>
  </div>
</section>
