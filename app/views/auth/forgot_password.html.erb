<div class="mx-auto mt-16 max-w-md w-full">
  <div class="overflow-hidden rounded-2xl border border-white/60 bg-white/60 backdrop-blur-xl p-8 shadow-lg">
    
    <div class="mb-8 text-center">
      <h2 class="text-2xl font-bold tracking-tight text-slate-900">Forgot Password?</h2>
      <p class="mt-2 text-sm text-slate-500">Enter your email to receive a reset link</p>
    </div>

    <%= form_with url: forgot_password_path, method: :post, local: true, class: "space-y-6" do |f| %>
      <div>
        <%= f.label :email, "Email Address", class: "mb-1.5 block text-sm font-medium text-slate-700" %>
        <%= f.email_field :email, class: "w-full rounded-lg border border-slate-200 bg-white/80 py-2.5 px-3.5 text-sm font-medium text-slate-900 shadow-sm transition-colors hover:border-slate-300 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/30", required: true, placeholder: "student@student.mmu.edu.my" %>
      </div>

      <div class="pt-2">
        <%= f.submit "Send Reset Link", class: "w-full inline-flex items-center justify-center gap-2 rounded-lg bg-blue-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition-all duration-200 hover:bg-blue-700 focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-600 focus-visible:ring-offset-2 cursor-pointer" %>
      </div>
    <% end %>

    <div class="mt-8 text-center">
      <p class="text-sm text-slate-500">
        <%= link_to "Back to Login", login_path, class: "font-semibold text-blue-600 hover:text-blue-500" %>
      </p>
    </div>
    
  </div>
</div>
