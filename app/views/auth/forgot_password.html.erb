<div class="glass-card">
  <div class="text-center mb-4">
    <h2>Forgot Password?</h2>
    <p style="color: var(--text-muted); font-size: 0.9rem;">Enter your email to receive a reset link</p>
  </div>

  <%= form_with url: forgot_password_path, method: :post, local: true do |f| %>
    <div class="form-group">
      <%= f.label :email, "Email Address", class: "form-label" %>
      <%= f.email_field :email, class: "form-control", required: true, placeholder: "student@student.mmu.edu.my" %>
    </div>

    <div class="mt-4">
      <%= f.submit "Send Reset Link", class: "btn btn-primary w-full" %>
    </div>
  <% end %>

  <div class="text-center mt-4">
    <%= link_to "Back to Login", login_path, style: "font-size: 0.9rem;" %>
  </div>
</div>
