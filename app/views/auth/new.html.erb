<div class="glass-card">
  <div class="text-center mb-4">
    <h2>Create an Account</h2>
    <p style="color: var(--text-muted); font-size: 0.9rem;">Join Student Peer Review</p>
  </div>

  <%= form_with model: @user, url: register_path, local: true do |f| %>
    <div class="form-group">
      <%= f.label :name, "Full Name", class: "form-label" %>
      <%= f.text_field :name, class: "form-control", required: true, placeholder: "John Doe" %>
    </div>

    <div class="form-group">
      <%= f.label :student_number, "Student Number (Optional)", class: "form-label" %>
      <%= f.text_field :student_number, class: "form-control", placeholder: "e.g. 1191100000" %>
    </div>

    <div class="form-group">
      <%= f.label :email, "Email Address", class: "form-label" %>
      <%= f.email_field :email, class: "form-control", required: true, placeholder: "student@student.mmu.edu.my" %>
      <small style="color: var(--text-muted); font-size: 0.75rem; margin-top: 4px; display: block;">Use an MMU email to automatically be assigned as Lecturer.</small>
    </div>

    <div class="form-group">
      <%= f.label :password, "Password", class: "form-label" %>
      <%= f.password_field :password, class: "form-control", required: true, placeholder: "••••••••" %>
    </div>
    
    <div class="form-group">
      <%= f.label :password_confirmation, "Confirm Password", class: "form-label" %>
      <%= f.password_field :password_confirmation, class: "form-control", required: true, placeholder: "••••••••" %>
    </div>

    <div class="mt-4">
      <%= f.submit "Register", class: "btn btn-primary w-full" %>
    </div>
  <% end %>

  <div class="text-center mt-4">
    <p style="font-size: 0.9rem; color: var(--text-muted);">
      Already have an account? <%= link_to "Log in", login_path %>
    </p>
  </div>
</div>
