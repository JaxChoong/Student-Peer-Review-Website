<div class="mx-auto mt-12 max-w-md w-full">
  <div class="overflow-hidden rounded-2xl border border-white/60 bg-white/60 backdrop-blur-xl p-8 shadow-lg">
    
    <div class="mb-8 text-center">
      <h2 class="text-2xl font-bold tracking-tight text-slate-900">Create an Account</h2>
      <p class="mt-2 text-sm text-slate-500">Join SPRS</p>
    </div>

    <%= form_with model: @user, url: register_path, local: true, class: "space-y-5", data: { controller: "registration-validation" } do |f| %>
      
      <% if @user.errors.any? %>
        <div class="rounded-xl bg-rose-50 p-4 text-sm font-medium text-rose-700 ring-1 ring-rose-600/20">
          <div class="flex items-center gap-2 mb-1.5">
            <svg class="h-5 w-5 text-rose-500 shrink-0" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
            </svg>
            <span class="font-bold">Registration failed</span>
          </div>
          <ul class="list-disc pl-5 space-y-1 text-xs text-rose-600/90 font-semibold">
            <% @user.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= f.label :name, "Full Name", class: "mb-1.5 block text-sm font-medium text-slate-700" %>
        <%= f.text_field :name, class: "w-full rounded-lg border py-2.5 px-3.5 text-sm font-medium text-slate-900 shadow-sm transition-colors focus:outline-none focus:ring-2 focus:ring-offset-0 #{ @user.errors[:name].any? ? 'border-rose-300 bg-rose-50/20 focus:border-rose-500 focus:ring-rose-500/20' : 'border-slate-200 bg-white/80 hover:border-slate-300 focus:border-blue-500 focus:ring-blue-500/30' }", required: true, placeholder: "John Doe" %>
      </div>

      <div>
        <%= f.label :student_number, "Student Number (Optional)", class: "mb-1.5 block text-sm font-medium text-slate-700" %>
        <%= f.text_field :student_number, class: "w-full rounded-lg border py-2.5 px-3.5 text-sm font-medium text-slate-900 shadow-sm transition-colors focus:outline-none focus:ring-2 focus:ring-offset-0 #{ @user.errors[:student_number].any? ? 'border-rose-300 bg-rose-50/20 focus:border-rose-500 focus:ring-rose-500/20' : 'border-slate-200 bg-white/80 hover:border-slate-300 focus:border-blue-500 focus:ring-blue-500/30' }", placeholder: "e.g. 1191100000" %>
      </div>

      <div>
        <%= f.label :email, "Email Address", class: "mb-1.5 block text-sm font-medium text-slate-700" %>
        <%= f.email_field :email, class: "w-full rounded-lg border py-2.5 px-3.5 text-sm font-medium text-slate-900 shadow-sm transition-colors focus:outline-none focus:ring-2 focus:ring-offset-0 #{ @user.errors[:email].any? ? 'border-rose-300 bg-rose-50/20 focus:border-rose-500 focus:ring-rose-500/20' : 'border-slate-200 bg-white/80 hover:border-slate-300 focus:border-blue-500 focus:ring-blue-500/30' }", required: true, placeholder: "student@student.mmu.edu.my" %>
        <p class="mt-1.5 text-[11px] text-slate-500 font-medium">Use an @mmu.edu.my email to automatically be assigned as Lecturer.</p>
      </div>

      <div>
        <%= f.label :password, "Password", class: "mb-1.5 block text-sm font-medium text-slate-700" %>
        <%= f.password_field :password, data: { registration_validation_target: "pwd", action: "input->registration-validation#updateCriteria" }, class: "w-full rounded-lg border py-2.5 px-3.5 text-sm font-medium text-slate-900 shadow-sm transition-colors focus:outline-none focus:ring-2 focus:ring-offset-0 #{ @user.errors[:password].any? ? 'border-rose-300 bg-rose-50/20 focus:border-rose-500 focus:ring-rose-500/20' : 'border-slate-200 bg-white/80 hover:border-slate-300 focus:border-blue-500 focus:ring-blue-500/30' }", required: true, placeholder: "••••••••", minlength: 6 %>
      </div>
      
      <div>
        <%= f.label :password_confirmation, "Confirm Password", class: "mb-1.5 block text-sm font-medium text-slate-700" %>
        <%= f.password_field :password_confirmation, data: { registration_validation_target: "pwdConf", action: "input->registration-validation#updateCriteria" }, class: "w-full rounded-lg border py-2.5 px-3.5 text-sm font-medium text-slate-900 shadow-sm transition-colors focus:outline-none focus:ring-2 focus:ring-offset-0 #{ @user.errors[:password_confirmation].any? ? 'border-rose-300 bg-rose-50/20 focus:border-rose-500 focus:ring-rose-500/20' : 'border-slate-200 bg-white/80 hover:border-slate-300 focus:border-blue-500 focus:ring-blue-500/30' }", required: true, placeholder: "••••••••", minlength: 6 %>
      </div>

      <!-- Real-time Password Checklist -->
      <div class="rounded-lg bg-slate-50 p-3 ring-1 ring-slate-200/50 space-y-1.5">
        <div id="criteria-length" data-registration-validation-target="lengthItem" class="flex items-center gap-1.5 text-xs text-slate-500 font-medium">
          <svg id="criteria-length-icon" data-registration-validation-target="lengthIcon" class="h-4 w-4 text-slate-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
          <span id="criteria-length-text">At least 6 characters</span>
        </div>
        <div id="criteria-match" data-registration-validation-target="matchItem" class="flex items-center gap-1.5 text-xs text-slate-500 font-medium">
          <svg id="criteria-match-icon" data-registration-validation-target="matchIcon" class="h-4 w-4 text-slate-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
          <span id="criteria-match-text">Passwords match</span>
        </div>
      </div>

      <div class="pt-3">
        <%= f.submit "Register", class: "w-full inline-flex items-center justify-center gap-2 rounded-lg bg-blue-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition-all duration-200 hover:bg-blue-700 focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-600 focus-visible:ring-offset-2 cursor-pointer" %>
      </div>
      
    <% end %>

    <div class="mt-8 text-center">
      <p class="text-sm text-slate-500">
        Already have an account? 
        <%= link_to "Log in", login_path, class: "font-semibold text-blue-600 hover:text-blue-500" %>
      </p>
    </div>
    
  </div>
</div>
