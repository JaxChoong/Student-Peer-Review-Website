<div class="glass-card">
  <div class="text-center mb-4">
    <h2>Change Password</h2>
    <p style="color: var(--text-muted); font-size: 0.9rem;">Update your account password</p>
  </div>

  <%= form_with url: change_password_path, method: :patch, local: true do |f| %>
    <div class="form-group">
      <%= f.label :current_password, "Current Password", class: "form-label" %>
      <%= f.password_field :current_password, class: "form-control", required: true, placeholder: "••••••••" %>
    </div>

    <div class="form-group">
      <%= f.label :new_password, "New Password", class: "form-label" %>
      <%= f.password_field :new_password, class: "form-control", required: true, placeholder: "••••••••" %>
    </div>
    
    <div class="form-group">
      <%= f.label :password_confirmation, "Confirm New Password", class: "form-label" %>
      <%= f.password_field :password_confirmation, class: "form-control", required: true, placeholder: "••••••••" %>
    </div>

    <div class="mt-4">
      <%= f.submit "Update Password", class: "btn btn-primary w-full" %>
    </div>
  <% end %>

  <div class="text-center mt-4">
    <%= link_to "Cancel", dashboard_path, class: "btn btn-secondary", style: "width: 100%;" %>
  </div>
</div>
