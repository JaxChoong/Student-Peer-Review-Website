<div class="glass-card">
  <div class="text-center mb-4">
    <h2>Reset Password</h2>
    <p style="color: var(--text-muted); font-size: 0.9rem;">Enter your new password below</p>
  </div>

  <%= form_with url: request.path, method: :patch, local: true do |f| %>
    <div class="form-group">
      <%= f.label :password, "New Password", class: "form-label" %>
      <%= f.password_field :password, class: "form-control", required: true, placeholder: "••••••••" %>
    </div>
    
    <div class="form-group">
      <%= f.label :password_confirmation, "Confirm New Password", class: "form-label" %>
      <%= f.password_field :password_confirmation, class: "form-control", required: true, placeholder: "••••••••" %>
    </div>

    <div class="mt-4">
      <%= f.submit "Update Password", class: "btn btn-primary w-full" %>
    </div>
  <% end %>
</div>
