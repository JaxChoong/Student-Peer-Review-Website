<div class="mx-auto mt-16 max-w-md w-full">
  <div class="overflow-hidden rounded-2xl border border-white/60 bg-white/60 backdrop-blur-xl p-8 shadow-lg">
    
    <div class="mb-8 text-center">
      <h2 class="text-2xl font-bold tracking-tight text-slate-900">Reset Password</h2>
      <p class="mt-2 text-sm text-slate-500">Enter your new password below</p>
    </div>

    <%= form_with url: request.path, method: :patch, local: true, class: "space-y-6" do |f| %>
      <div>
        <%= f.label :password, "New Password", class: "mb-1.5 block text-sm font-medium text-slate-700" %>
        <%= f.password_field :password, class: "w-full rounded-lg border border-slate-200 bg-white/80 py-2.5 px-3.5 text-sm font-medium text-slate-900 shadow-sm transition-colors hover:border-slate-300 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/30", required: true, placeholder: "••••••••" %>
      </div>
      
      <div>
        <%= f.label :password_confirmation, "Confirm New Password", class: "mb-1.5 block text-sm font-medium text-slate-700" %>
        <%= f.password_field :password_confirmation, class: "w-full rounded-lg border border-slate-200 bg-white/80 py-2.5 px-3.5 text-sm font-medium text-slate-900 shadow-sm transition-colors hover:border-slate-300 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/30", required: true, placeholder: "••••••••" %>
      </div>

      <div class="pt-2">
        <%= f.submit "Update Password", class: "w-full inline-flex items-center justify-center gap-2 rounded-lg bg-blue-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition-all duration-200 hover:bg-blue-700 focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-600 focus-visible:ring-offset-2 cursor-pointer" %>
      </div>
    <% end %>
    
  </div>
</div>
