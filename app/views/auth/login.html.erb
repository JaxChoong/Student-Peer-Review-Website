<div class="glass-card">
  <div class="text-center mb-4">
    <h2>Welcome Back</h2>
    <p style="color: var(--text-muted); font-size: 0.9rem;">Sign in to continue to Student Peer Review</p>
  </div>

  <%= form_with url: login_path, method: :post, class: "accountForms", local: true do |f| %>
    <div class="form-group">
      <%= f.label :email, "Email Address", class: "form-label" %>
      <%= f.email_field :email, class: "form-control", required: true, placeholder: "student@student.mmu.edu.my", autocomplete: "email" %>
    </div>

    <div class="form-group">
      <div class="flex justify-between items-center mb-2">
        <%= f.label :password, "Password", class: "form-label", style: "margin-bottom: 0;" %>
        <%= link_to "Forgot Password?", forgot_password_path, style: "font-size: 0.85rem;" %>
      </div>
      <%= f.password_field :password, class: "form-control", required: true, placeholder: "••••••••" %>
    </div>

    <div class="mt-4">
      <%= f.submit "Log in", class: "btn btn-primary w-full" %>
    </div>
  <% end %>

  <div class="text-center mt-4">
    <p style="font-size: 0.9rem; color: var(--text-muted);">
      Don't have an account? <%= link_to "Sign up", register_path %>
    </p>
  </div>
</div>
