<div class="mx-auto mt-12 max-w-2xl w-full">
  <div class="mb-6 flex items-center justify-between">
    <h2 class="text-2xl font-bold tracking-tight text-slate-900">Add New Course</h2>
    <%= link_to "Back to Dashboard", dashboard_path, class: "inline-flex items-center gap-2 rounded-lg border border-white/60 bg-white/60 backdrop-blur-md px-3.5 py-2 text-sm font-semibold text-slate-700 shadow-sm transition-colors hover:bg-white/80 focus:outline-none focus-visible:ring-2 focus-visible:ring-slate-400 focus-visible:ring-offset-2" %>
  </div>

  <div class="overflow-hidden rounded-2xl border border-white/60 bg-white/60 backdrop-blur-xl p-8 shadow-lg">
    
    <p class="mb-8 text-sm text-slate-600">
      Fill in the details below to create your course. You can import students via CSV after the course is created.
    </p>

    <div class="rounded-xl border-2 border-dashed border-white/80 bg-white/40 p-8 transition-colors hover:border-blue-300 hover:bg-blue-50/50" data-controller="course-settings">
      <%= form_with url: courses_path, method: :post, local: true, class: "flex flex-col gap-6" do |f| %>
        
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
          <div>
            <%= f.label :course_code, "Course Code", class: "block text-sm font-semibold text-slate-900 mb-2" %>
            <%= f.text_field :course_code, class: "block w-full rounded-lg border-slate-300 py-2.5 px-4 text-slate-900 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm", required: true, placeholder: "e.g. CS101" %>
          </div>
          <div>
            <%= f.label :course_name, "Course Name", class: "block text-sm font-semibold text-slate-900 mb-2" %>
            <%= f.text_field :course_name, class: "block w-full rounded-lg border-slate-300 py-2.5 px-4 text-slate-900 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm", required: true, placeholder: "e.g. Intro to Computer Science" %>
          </div>
          <div>
            <%= f.label :start_date, "Review Start Date", class: "block text-sm font-semibold text-slate-900 mb-2" %>
            <%= f.date_field :start_date, class: "block w-full rounded-lg border-slate-300 py-2.5 px-4 text-slate-900 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm", required: true %>
          </div>
          <div>
            <%= f.label :end_date, "Review End Date", class: "block text-sm font-semibold text-slate-900 mb-2" %>
            <%= f.date_field :end_date, class: "block w-full rounded-lg border-slate-300 py-2.5 px-4 text-slate-900 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm", required: true %>
          </div>
        </div>

        <div>
          <%= f.label :review_mode, "Review Mode", class: "block text-sm font-semibold text-slate-900 mb-2" %>
          <%= f.select :review_mode, [["Peer Ratings Only Mode (Only Export Average Peer Ratings)", 0], ["Hybrid Mode (Group Mark + Peer Ratings + Lecturer Evaluation)", 1]], {}, class: "block w-full rounded-lg border-slate-300 py-2.5 px-4 text-slate-900 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm", data: { course_settings_target: "reviewModeSelect", action: "change->course-settings#toggleScoringScheme" } %>
        </div>

        <div>
          <%= f.label :scoring_scheme, "Scoring Scheme", class: "block text-sm font-semibold text-slate-900 mb-2" %>
          <%= f.select :scoring_scheme, [["Numeric — 1-5 rating with normalization (default)", 0], ["Rubric — custom matrix (assign template after creation)", 1], ["Fixed Point Pool (100 points)", 2]], {}, class: "block w-full rounded-lg border-slate-300 py-2.5 px-4 text-slate-900 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm", data: { course_settings_target: "scoringSchemeSelect" } %>
        </div>

        <div>
          <%= f.label :introduction, "Course Introduction (Optional)", class: "block text-sm font-semibold text-slate-900 mb-2" %>
          <%= f.text_area :introduction, rows: 4, class: "block w-full rounded-lg border-slate-300 py-2.5 px-4 text-slate-900 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm", placeholder: "Add a markdown introduction that students will see at the top of the peer review page..." %>
        </div>

        <div class="flex items-center gap-3 bg-white/60 p-4 rounded-xl border border-slate-200">
          <%= f.check_box :require_self_review, checked: true, class: "h-5 w-5 rounded border-slate-300 text-blue-600 focus:ring-blue-500 cursor-pointer" %>
          <div>
            <%= f.label :require_self_review, "Require Self Review (Comments)", class: "block text-sm font-semibold text-slate-900 cursor-pointer" %>
            <p class="text-xs text-slate-500 mt-0.5">If disabled, the self-review questions will be hidden from the student form.</p>
          </div>
        </div>

        <div class="mt-2 text-center">
          <%= f.submit "Create Course", class: "inline-flex items-center justify-center gap-2 rounded-lg bg-blue-600 px-8 py-3 text-sm font-semibold text-white shadow-sm transition-all duration-200 hover:bg-blue-700 hover:-translate-y-0.5 focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-600 focus-visible:ring-offset-2 cursor-pointer" %>
        </div>
      <% end %>
    </div>

  </div>
</div>
