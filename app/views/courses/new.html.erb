<div class="mx-auto mt-12 max-w-2xl w-full">
  <div class="mb-6 flex items-center justify-between">
    <h2 class="text-2xl font-bold tracking-tight text-slate-900">Add New Course</h2>
    <%= link_to "Back to Dashboard", dashboard_path, class: "inline-flex items-center gap-2 rounded-lg border border-white/60 bg-white/60 backdrop-blur-md px-3.5 py-2 text-sm font-semibold text-slate-700 shadow-sm transition-colors hover:bg-white/80 focus:outline-none focus-visible:ring-2 focus-visible:ring-slate-400 focus-visible:ring-offset-2" %>
  </div>

  <div class="overflow-hidden rounded-2xl border border-white/60 bg-white/60 backdrop-blur-xl p-8 shadow-lg">
    
    <p class="mb-8 text-sm text-slate-600">
      Upload a CSV file containing your students' details. The system will automatically create the course, sections, groups, and student accounts based on the provided data.
    </p>

    <div class="rounded-xl border-2 border-dashed border-white/80 bg-white/40 p-8 text-center transition-colors hover:border-blue-300 hover:bg-blue-50/50">
      <%= form_with url: courses_path, method: :post, multipart: true, local: true, class: "flex flex-col items-center justify-center gap-6" do |f| %>
        
        <div class="w-full max-w-sm">
          <div class="mb-3 inline-flex h-12 w-12 items-center justify-center rounded-full bg-blue-100 text-blue-600">
            <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"></path></svg>
          </div>
          <%= f.label :file, "Select CSV File", class: "block text-lg font-semibold text-slate-900 mb-4" %>
          <%= f.file_field :file, accept: ".csv", class: "block w-full text-sm text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-blue-600 file:text-white hover:file:bg-blue-700 transition-colors cursor-pointer", required: true %>
        </div>
        
        <div class="text-sm text-slate-500 bg-white/50 px-4 py-3 rounded-lg">
          <p><strong class="text-slate-700">Required columns:</strong> email, name, section, group</p>
          <p class="mt-1"><strong class="text-slate-700">Optional columns:</strong> studentId</p>
        </div>

        <%= f.submit "Upload & Create Course", class: "inline-flex items-center justify-center gap-2 rounded-lg bg-blue-600 px-6 py-3 text-sm font-semibold text-white shadow-sm transition-all duration-200 hover:bg-blue-700 hover:-translate-y-0.5 focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-600 focus-visible:ring-offset-2 cursor-pointer mt-2" %>
      <% end %>
    </div>
    
    <div class="mt-6 text-center">
      <%= link_to "Download Example CSV", example_csv_path, class: "text-sm font-semibold text-blue-600 transition-colors hover:text-blue-500 underline underline-offset-4 decoration-blue-200 hover:decoration-blue-500" %>
    </div>

  </div>
</div>
