<div class="relative isolate overflow-hidden">
  <div
    class="
      mx-auto max-w-7xl px-6 pb-24 pt-2 sm:pb-32 lg:flex lg:items-center lg:gap-x-10
      lg:px-8 lg:py-30
    "
  >
    <div class="mx-auto max-w-2xl lg:mx-0 lg:max-w-xl lg:flex-shrink-0">
      <div class="mt-10 sm:mt-16 lg:mt-0">
        <span
          class="
            inline-flex items-center space-x-2 rounded-full bg-blue-600/10 px-3 py-1 text-sm
            font-semibold leading-6 text-blue-600 ring-1 ring-inset ring-blue-600/20
          "
        >
          <span>v2.0 Beta Release</span>
        </span>
      </div>
      <h1
        class="
          mt-10 text-4xl font-bold tracking-tight text-slate-900 sm:text-6xl text-balance
        "
      >Modern Peer Review for Higher Education.</h1>
      <p class="mt-6 text-lg leading-8 text-slate-600 text-balance">
        Automate group evaluations, streamline grading workflows, and empower
        students with structured feedback. The only peer assessment platform
        your course will ever need.
      </p>
      <div class="mt-10 flex items-center gap-x-6">
        <%= link_to "Get Started",
        register_path,
        class:
          "rounded-lg bg-blue-600 px-5 py-3 text-sm font-semibold text-white shadow-sm hover:bg-blue-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600 transition-all duration-200" %>
        <%= link_to "Login",
        login_path,
        class:
          "rounded-lg border border-slate-200 bg-white px-5 py-3 text-sm font-semibold text-slate-900 shadow-sm hover:bg-slate-50 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-slate-600 transition-all duration-200" %>
      </div>
    </div>

    <div class="mx-auto mt-16 flex-1 w-full lg:ml-10 lg:mt-0">
      <div class="w-full">
        <div
          class="
            rounded-xl bg-white/40 p-2 ring-1 ring-inset ring-white/60 backdrop-blur-3xl
            shadow-2xl lg:rounded-2xl lg:p-4
          "
        >
          <div
            class="
              rounded-md bg-white shadow-xl ring-1 ring-slate-900/10 overflow-hidden w-full
            "
          >
            <!-- Faux UI for the screenshot feel -->
            <div
              class="
                flex items-center gap-x-2 border-b border-slate-200 bg-slate-50 px-4 py-3
              "
            >
              <div class="flex gap-x-1.5">
                <div class="h-3 w-3 rounded-full bg-rose-400"></div>
                <div class="h-3 w-3 rounded-full bg-amber-400"></div>
                <div class="h-3 w-3 rounded-full bg-emerald-400"></div>
              </div>
              <div class="ml-4 text-xs font-medium text-slate-500 flex-1 text-center pr-12">sprs.live</div>
            </div>

            <div class="p-6 bg-slate-50">
              <div
                class="
                  mb-4 flex items-center justify-between border-b border-slate-200 pb-4
                "
              >
                <div>
                  <h3 class="font-bold text-slate-900">Final Marks</h3>
                  <p class="text-xs text-slate-500">SE3401 · Section A</p>
                </div>
              </div>

              <div class="space-y-3">
                <div
                  class="
                    flex items-center justify-between rounded-lg border border-slate-200 bg-white
                    p-3 shadow-sm
                  "
                >
                  <div class="flex items-center gap-3">
                    <span
                      class="
                        flex h-8 w-8 items-center justify-center rounded-full bg-blue-100 text-[10px]
                        font-bold text-blue-700
                      "
                    >JD</span>
                    <div>
                      <p class="text-sm font-semibold text-slate-900">Jane Doe</p>
                      <p class="text-xs text-slate-500">Group 1</p>
                    </div>
                  </div>
                  <span
                    class="
                      inline-flex items-center rounded-md bg-emerald-50 px-2 py-1 text-xs font-bold
                      text-emerald-700 ring-1 ring-inset ring-emerald-600/20
                    "
                  >85</span>
                </div>

                <div
                  class="
                    flex items-center justify-between rounded-lg border border-slate-200 bg-white
                    p-3 shadow-sm
                  "
                >
                  <div class="flex items-center gap-3">
                    <span
                      class="
                        flex h-8 w-8 items-center justify-center rounded-full bg-indigo-100 text-[10px]
                        font-bold text-indigo-700
                      "
                    >AS</span>
                    <div>
                      <p class="text-sm font-semibold text-slate-900">Alex Smith</p>
                      <p class="text-xs text-slate-500">Group 1</p>
                    </div>
                  </div>
                  <span
                    class="
                      inline-flex items-center rounded-md bg-amber-50 px-2 py-1 text-xs font-bold
                      text-amber-700 ring-1 ring-inset ring-amber-600/20
                    "
                  >64</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
