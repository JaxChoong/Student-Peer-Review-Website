<!-- ========================================================= SECTION 3: ASSESSMENT FORMULA & CALCULATOR ========================================================= -->
<section class="py-24 sm:py-32 bg-slate-900 text-white relative overflow-hidden">
  <!-- Glowing Background Decors -->
  <div class="absolute -left-1/4 -top-1/4 w-1/2 h-1/2 bg-blue-500/10 blur-[100px] rounded-full pointer-events-none"></div>
  <div class="absolute -right-1/4 -bottom-1/4 w-1/2 h-1/2 bg-indigo-500/10 blur-[100px] rounded-full pointer-events-none"></div>

  <div class="mx-auto max-w-7xl px-6 lg:px-8 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      
      <!-- Text & Formula Details -->
      <div>
        <h2 class="text-base font-semibold leading-7 text-blue-400 uppercase tracking-wider">The Grading Engine</h2>
        <h3 class="mt-2 text-3xl font-extrabold tracking-tight text-white sm:text-4xl">
          Fair Grading Built on Rigorous Formulas
        </h3>
        <p class="mt-6 text-lg text-slate-300 leading-8">
          The system protects students from unfair grading using a hybrid formula. It balances the lecturer's project assessment, peer scores, and individual lecturer evaluations.
        </p>

        <!-- Formula Definition Card -->
        <div class="mt-8 bg-white/5 border border-white/10 rounded-2xl p-6 backdrop-blur-md">
          <h4 class="font-bold text-lg text-blue-400 mb-2">Final Mark Calculation Formula</h4>
          <p class="text-sm text-slate-300 mb-4">
            A student's final score is calculated using three distinct metrics (weighted at 50% Group Mark, 25% Peer Rating, and 25% Lecturer Rating):
          </p>
          <div class="bg-black/35 p-6 rounded-2xl border border-white/5 overflow-x-auto">
            <div class="flex flex-wrap items-center justify-start md:justify-center gap-y-4 gap-x-2 font-mono text-sm md:text-base leading-none select-none text-blue-300">
              <!-- Final Mark -->
              <span class="font-bold text-white px-2 py-1 bg-blue-600/30 rounded border border-blue-500/30">Final Score</span>
              
              <span class="text-slate-500 font-bold">=</span>
              
              <!-- Term 1: 0.50 * AM -->
              <div class="flex items-center gap-1.5 bg-white/5 px-3 py-3 rounded-xl border border-white/10">
                <span class="text-slate-300">0.50</span>
                <span class="text-slate-500 font-bold">×</span>
                <span class="text-white font-semibold">AM</span>
              </div>
              
              <span class="text-slate-500 font-bold text-lg">+</span>
              
              <!-- Term 2: 0.25 * AM * (APR / 3.0) -->
              <div class="flex items-center gap-1.5 bg-white/5 px-3 py-3 rounded-xl border border-white/10">
                <span class="text-slate-300">0.25</span>
                <span class="text-slate-500 font-bold">×</span>
                <span class="text-white font-semibold">AM</span>
                <span class="text-slate-500 font-bold">×</span>
                <!-- Fraction -->
                <div class="flex flex-col items-center px-1">
                  <span class="pb-1.5 border-b border-white/20 text-blue-400 font-bold text-xs tracking-wider">APR</span>
                  <span class="pt-1.5 text-xs text-slate-400">3.0</span>
                </div>
              </div>
              
              <span class="text-slate-500 font-bold text-lg">+</span>
              
              <!-- Term 3: 0.25 * AM * (LE / 3.0) -->
              <div class="flex items-center gap-1.5 bg-white/5 px-3 py-3 rounded-xl border border-white/10">
                <span class="text-slate-300">0.25</span>
                <span class="text-slate-500 font-bold">×</span>
                <span class="text-white font-semibold">AM</span>
                <span class="text-slate-500 font-bold">×</span>
                <!-- Fraction -->
                <div class="flex flex-col items-center px-1">
                  <span class="pb-1.5 border-b border-white/20 text-indigo-400 font-bold text-xs tracking-wider">LE</span>
                  <span class="pt-1.5 text-xs text-slate-400">3.0</span>
                </div>
              </div>
            </div>
          </div>
          <ul class="mt-4 space-y-2 text-xs text-slate-400">
            <li><strong class="text-white">AM (Assignment Mark):</strong> The final mark given to the team's project by the lecturer (0-100%).</li>
            <li><strong class="text-white">APR (Average Peer Rating):</strong> The average score received from teammate evaluations (0.0 - 3.0).</li>
            <li><strong class="text-white">LE (Lecturer Evaluation):</strong> A student-specific rating assigned by the lecturer (0.0 - 3.0). Defaults to APR if not specified.</li>
            <li><strong class="text-rose-400">Self-Review Penalty:</strong> If a student fails to submit peer reviews, their final mark is automatically set to <strong class="text-rose-400">0%</strong>.</li>
          </ul>
        </div>
      </div>

      <!-- Live Interactive Calculator -->
      <div class="bg-white/10 border border-white/15 rounded-3xl p-8 backdrop-blur-xl shadow-2xl" data-controller="calculator">
        <h4 class="text-xl font-bold mb-6 text-center text-white flex items-center justify-center gap-2">
          <svg class="h-6 w-6 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 11h.01M12 7h.01M15 11h.01M12 14h.01M4.01 4h16v16h-16z" />
          </svg>
          Interactive Grade Estimator
        </h4>
        
        <div class="space-y-6">
          <!-- Slide 1: Group Mark -->
          <div>
            <div class="flex justify-between text-sm font-medium mb-2">
              <label for="group-mark-input" class="text-slate-300">Group Assignment Mark (AM)</label>
              <span class="text-blue-400 font-bold" id="group-mark-val" data-calculator-target="groupMarkVal">80%</span>
            </div>
            <input type="range" id="group-mark-input" min="0" max="100" value="80" 
              data-calculator-target="groupMarkInput" data-action="input->calculator#updateCalculator"
              class="w-full h-2 bg-slate-700 rounded-lg appearance-none cursor-pointer accent-blue-500">
          </div>

          <!-- Slide 2: Peer Rating -->
          <div>
            <div class="flex justify-between text-sm font-medium mb-2">
              <label for="peer-rating-input" class="text-slate-300">Average Peer Rating (APR)</label>
              <span class="text-blue-400 font-bold" id="peer-rating-val" data-calculator-target="peerRatingVal">2.5 / 3.0</span>
            </div>
            <input type="range" id="peer-rating-input" min="0" max="3" step="0.1" value="2.5" 
              data-calculator-target="peerRatingInput" data-action="input->calculator#updateCalculator"
              class="w-full h-2 bg-slate-700 rounded-lg appearance-none cursor-pointer accent-blue-500">
          </div>

          <!-- Slide 3: Lecturer Rating -->
          <div>
            <div class="flex justify-between text-sm font-medium mb-2">
              <label for="lecturer-rating-input" class="text-slate-300">Lecturer Evaluation (LE)</label>
              <span class="text-blue-400 font-bold" id="lecturer-rating-val" data-calculator-target="lecturerRatingVal">2.5 / 3.0</span>
            </div>
            <input type="range" id="lecturer-rating-input" min="0" max="3" step="0.1" value="2.5" 
              data-calculator-target="lecturerRatingInput" data-action="input->calculator#updateCalculator"
              class="w-full h-2 bg-slate-700 rounded-lg appearance-none cursor-pointer accent-blue-500">
          </div>

          <!-- Checkbox: Completed Peer Review -->
          <div class="relative flex items-start bg-slate-800/40 p-4 rounded-xl border border-white/5">
            <div class="flex h-6 items-center">
              <input id="submitted-reviews" name="submitted-reviews" type="checkbox" checked
                data-calculator-target="submittedReviewsCheckbox" data-action="change->calculator#updateCalculator"
                class="h-4 w-4 rounded border-slate-600 bg-slate-700 text-blue-600 focus:ring-blue-500">
            </div>
            <div class="ml-3 text-sm leading-6">
              <label for="submitted-reviews" class="font-medium text-slate-200">Completed Required Reviews</label>
              <p class="text-slate-400 text-xs">Uncheck this to trigger the non-submission penalty.</p>
            </div>
          </div>

          <!-- Result Area -->
          <div class="pt-6 border-t border-white/10 text-center">
            <p class="text-xs uppercase tracking-widest text-slate-400 font-medium">Estimated Individual Mark</p>
            <div class="mt-2 text-5xl font-extrabold text-blue-400 transition-all duration-300" id="final-calculated-val" data-calculator-target="finalCalculatedVal">
              80.00%
            </div>
            
            <p class="text-[11px] text-slate-400 mt-3" id="calc-explanation" data-calculator-target="calcExplanation">
              Calculation: (0.50 × 80.00) + (0.25 × 80.00 × (2.50 / 3.0)) + (0.25 × 80.00 × (2.50 / 3.0))
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>


</section>

