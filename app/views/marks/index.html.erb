<!-- =========================================================
     4. MARKS DATATABLE
========================================================== -->
<section class="mb-20">
  <div class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <h2 class="text-2xl font-bold tracking-tight text-slate-900">Final Marks</h2>
      <p class="mt-1 text-sm text-slate-500"><%= @course.course_code %> &middot; <%= @course.course_name %></p>
    </div>
    
    <div class="flex flex-col items-end gap-1.5">
      <div class="flex items-center gap-2">
        <a href="<%= dashboard_path %>" class="inline-flex items-center gap-2 rounded-lg border border-slate-200 bg-white px-3.5 py-2 text-sm font-semibold text-slate-700 shadow-sm transition-colors hover:bg-slate-50 focus:outline-none focus-visible:ring-2 focus-visible:ring-slate-400 focus-visible:ring-offset-2">
          Back
        </a>
          <a href="<%= export_final_course_marks_path(@course) %>" class="inline-flex items-center gap-2 rounded-lg bg-blue-600 px-3.5 py-2 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-blue-700 focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-600 focus-visible:ring-offset-2">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><path d="M7 10l5 5 5-5"/><path d="M12 15V3"/></svg>
            Export Final CSV
          </a>
      </div>
      <% if @course.normalised_peer_ratings? %>
        <% if @groups_with_marks == 0 %>
          <span class="text-xs font-semibold text-rose-600 bg-rose-50 border border-rose-100 rounded-md px-3 py-1 inline-flex items-center gap-1">
            Pending: Upload lecturer group marks to calculate Final Marks
          </span>
        <% elsif @groups_with_marks < @total_groups %>
          <span class="text-xs font-semibold text-amber-600 bg-amber-50 border border-amber-100 rounded-md px-3 py-1 inline-flex items-center gap-1">
            ⚠️ Warning: Only <%= @groups_with_marks %> of <%= @total_groups %> groups have marks. Missing marks default to 0.0.
          </span>
        <% end %>
      <% end %>
    </div>
  </div>

  <% if @course.normalised_peer_ratings? %>
    <!-- Import Panel (Custom addition on top of v0) -->
    <div class="mb-8 rounded-2xl border border-white/60 bg-white/60 backdrop-blur-xl shadow-lg relative">
      <div class="border-b border-white/40 bg-white/40 px-6 py-4 rounded-t-2xl flex items-center gap-2">
        <h3 class="text-sm font-bold tracking-tight text-slate-900">Import Lecturer Marks</h3>
        
        <div class="group relative flex items-center justify-center">
          <svg class="h-4 w-4 text-slate-400 hover:text-blue-500 cursor-help transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          <div class="pointer-events-none absolute left-1/2 bottom-full z-50 mb-2 w-72 -translate-x-1/2 opacity-0 transition-opacity duration-300 group-hover:opacity-100">
            <div class="rounded-lg bg-slate-900 px-3 py-2.5 text-xs font-medium text-white shadow-lg leading-relaxed text-center">
              Download the template, fill in the <strong>Group Mark</strong> (max 100) and <strong>Lecturer Rating</strong> (max 3), then upload it back here.
              <svg class="absolute left-1/2 top-full h-2 w-full -translate-x-1/2 text-slate-900" x="0px" y="0px" viewBox="0 0 255 255" xml:space="preserve"><polygon class="fill-current" points="0,0 127.5,127.5 255,0"/></svg>
            </div>
          </div>
        </div>
      </div>
      <div class="px-6 py-5 flex flex-col sm:flex-row items-center gap-4">
        <a href="<%= export_template_course_marks_path(@course) %>" class="inline-flex items-center gap-2 rounded-lg border border-slate-200 bg-white px-3.5 py-2.5 text-sm font-semibold text-slate-700 shadow-sm transition-colors hover:bg-slate-50">
          <svg class="h-4 w-4 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
          Download Template
        </a>
        
        <%= form_with url: import_course_marks_path(@course), local: true, multipart: true, class: "flex w-full sm:w-auto items-center gap-2" do |f| %>
          <%= f.file_field :file, accept: ".csv", class: "block w-full text-sm text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100 transition-colors" %>
          <%= f.submit "Upload", class: "inline-flex items-center gap-2 rounded-lg bg-slate-900 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-slate-800 cursor-pointer" %>
        <% end %>
      </div>
    </div>
  <% end %>

  <div class="overflow-hidden rounded-2xl border border-white/60 bg-white/60 backdrop-blur-xl shadow-lg">
    <div class="overflow-x-auto">
      <table class="w-full text-left text-sm">
        <thead>
          <tr class="border-b border-white/40 bg-white/40">
            <th scope="col" class="px-6 py-3.5 text-xs font-semibold uppercase tracking-wider text-slate-500">Student</th>
            <th scope="col" class="px-6 py-3.5 text-xs font-semibold uppercase tracking-wider text-slate-500">Group</th>
            <th scope="col" class="px-6 py-3.5 text-center text-xs font-semibold uppercase tracking-wider text-slate-500">Peer Avg</th>
            <% if @course.normalised_peer_ratings? %>
              <th scope="col" class="px-6 py-3.5 text-center text-xs font-semibold uppercase tracking-wider text-slate-500">Lecturer</th>
              <th scope="col" class="px-6 py-3.5 text-center text-xs font-semibold uppercase tracking-wider text-slate-500">Final Mark</th>
            <% end %>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @student_marks.each do |sm| %>
            <tr class="transition-colors hover:bg-slate-50/70">
              <td class="px-6 py-4">
                <div class="flex items-center gap-3">
                  <span class="flex h-9 w-9 items-center justify-center rounded-full bg-slate-100 text-xs font-bold text-slate-700">
                    <%= sm[:student].name.split.map(&:first).join.upcase.slice(0, 2) %>
                  </span>
                  <div>
                    <p class="font-semibold text-slate-900">
                      <%= sm[:student].name %>
                      <% if sm[:result][:penalty] %>
                        <span class="ml-2 inline-flex items-center rounded-md bg-rose-50 px-1.5 py-0.5 text-xs font-medium text-rose-700 ring-1 ring-inset ring-rose-600/20">Penalty</span>
                      <% end %>
                    </p>
                    <p class="text-xs text-slate-500"><%= sm[:student].email %></p>
                  </div>
                </div>
              </td>
              <td class="px-6 py-4 text-slate-600"><%= sm[:group].group_name %></td>
              <td class="px-6 py-4 text-center font-medium text-slate-600"><%= sm[:result][:apr] %></td>
              <% if @course.normalised_peer_ratings? %>
                <td class="px-6 py-4 text-center font-medium text-slate-600"><%= sm[:result][:le] %></td>
                <td class="px-6 py-4 text-center">
                  <% 
                    final_mark = sm[:result][:final_mark]
                    color_class = if final_mark >= 80
                                    "bg-emerald-50 text-emerald-700 ring-emerald-600/20"
                                  elsif final_mark >= 50
                                    "bg-amber-50 text-amber-700 ring-amber-600/20"
                                  else
                                    "bg-rose-50 text-rose-700 ring-rose-600/20"
                                  end
                  %>
                  <span class="inline-flex min-w-[3.5rem] items-center justify-center rounded-lg px-3 py-1.5 text-sm font-bold ring-1 ring-inset <%= color_class %>">
                    <%= final_mark %>
                  </span>
                </td>
              <% end %>
            </tr>
          <% end %>

          <% if @student_marks.empty? %>
            <tr>
              <td colspan="<%= @course.normalised_peer_ratings? ? 5 : 3 %>" class="px-6 py-8 text-center text-sm text-slate-500">
                No students enrolled in groups for this course yet.
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <!-- Table footer -->
    <div class="flex items-center justify-between border-t border-white/40 bg-white/40 px-6 py-3.5">
      <p class="text-xs text-slate-500">Showing <span class="font-semibold text-slate-700"><%= @student_marks.length %></span> students</p>
    </div>
  </div>
</section>
