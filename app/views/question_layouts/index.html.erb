<div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
  <div>
    <h2 class="text-2xl font-bold tracking-tight text-slate-900">Question Customizations</h2>
    <p class="mt-1 text-sm text-slate-500">Manage templates for peer review questions</p>
  </div>
  <%= link_to "Back to Dashboard", dashboard_path, class: "inline-flex items-center gap-2 rounded-lg border border-white/60 bg-white/60 backdrop-blur-md px-3.5 py-2 text-sm font-semibold text-slate-700 shadow-sm transition-colors hover:bg-white/80 focus:outline-none focus-visible:ring-2 focus-visible:ring-slate-400 focus-visible:ring-offset-2" %>
</div>

<!-- Create New Layout -->
<div class="mb-8 overflow-hidden rounded-2xl border border-white/60 bg-white/60 backdrop-blur-xl shadow-lg p-6 sm:p-8">
  <h3 class="mb-4 text-lg font-bold tracking-tight text-slate-900">Create New Layout</h3>
  
  <%= form_with model: QuestionLayout.new, url: question_layouts_path, local: true, class: "flex flex-col sm:flex-row items-end gap-4" do |f| %>
    <div class="w-full sm:w-auto flex-1">
      <%= f.label :layout_name, "Layout Name", class: "mb-1.5 block text-sm font-medium text-slate-700" %>
      <%= f.text_field :layout_name, class: "w-full rounded-lg border border-slate-200 bg-white/80 py-2.5 px-3.5 text-sm font-medium text-slate-900 shadow-sm transition-colors hover:border-slate-300 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/30", required: true, placeholder: "e.g. IT Project 2024" %>
    </div>
    <%= f.submit "Create Layout", class: "inline-flex w-full sm:w-auto items-center justify-center gap-2 rounded-lg bg-blue-600 px-6 py-2.5 text-sm font-semibold text-white shadow-sm transition-all duration-200 hover:bg-blue-700 hover:-translate-y-0.5 focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-600 focus-visible:ring-offset-2 cursor-pointer" %>
  <% end %>
</div>

<div class="space-y-8">
  
  <!-- System Default Layout -->
  <% if @system_layouts.any? %>
    <div class="overflow-hidden rounded-2xl border border-white/60 bg-white/60 backdrop-blur-xl shadow-lg border-l-4 border-l-blue-500">
      <div class="border-b border-white/40 bg-white/40 px-6 py-4 flex items-center justify-between">
        <h3 class="text-lg font-bold tracking-tight text-slate-900">System Default</h3>
        <span class="inline-flex items-center rounded-md bg-slate-100 px-2 py-1 text-xs font-semibold text-slate-600 ring-1 ring-inset ring-slate-500/10">Read Only</span>
      </div>
      
      <div class="px-6 py-5">
        <ul class="divide-y divide-slate-100">
          <% @system_layouts.first.questions.each_with_index do |q, index| %>
            <li class="py-3 text-sm font-medium text-slate-600 flex items-start gap-3">
              <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-slate-100 text-xs font-bold text-slate-500"><%= index + 1 %></span>
              <span class="pt-0.5"><%= q.question_text %></span>
            </li>
          <% end %>
        </ul>
      </div>
    </div>
  <% end %>

  <!-- My Custom Layouts -->
  <% @my_layouts.each do |layout| %>
    <div class="overflow-hidden rounded-2xl border border-white/60 bg-white/60 backdrop-blur-xl shadow-lg">
      <div class="border-b border-white/40 bg-white/40 px-6 py-4 flex items-center justify-between">
        <h3 class="text-lg font-bold tracking-tight text-slate-900"><%= layout.layout_name %></h3>
        <%= button_to "Delete Layout", question_layout_path(layout), method: :delete, form: { data: { turbo_confirm: "Delete this layout?" } }, class: "inline-flex items-center gap-1.5 rounded-md bg-rose-50 px-2.5 py-1.5 text-xs font-semibold text-rose-700 ring-1 ring-inset ring-rose-600/20 transition-colors hover:bg-rose-100 cursor-pointer" %>
      </div>

      <div class="p-6">
        <!-- Add Question Form -->
        <div class="mb-6 rounded-xl border border-slate-200 bg-white/50 p-4">
          <%= form_with model: Question.new, url: question_layout_questions_path(layout), local: true, class: "flex items-center shadow-sm rounded-lg overflow-hidden" do |f| %>
            <%= f.text_field :question_text, class: "flex-1 border-0 py-2.5 px-4 text-sm font-medium text-slate-900 focus:ring-0", required: true, placeholder: "Add a new question..." %>
            <%= f.submit "Add", class: "bg-slate-100 px-6 py-2.5 text-sm font-semibold text-slate-700 hover:bg-slate-200 cursor-pointer transition-colors" %>
          <% end %>
        </div>

        <!-- Questions List -->
        <% if layout.questions.any? %>
          <ul class="divide-y divide-slate-100 rounded-xl border border-slate-200 bg-white/80 p-2 shadow-sm">
            <% layout.questions.each_with_index do |q, index| %>
              <li class="flex items-center justify-between py-3 px-4 text-sm font-medium text-slate-700 group hover:bg-slate-50 rounded-lg transition-colors">
                <div class="flex items-start gap-3">
                  <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-blue-50 text-xs font-bold text-blue-600"><%= index + 1 %></span>
                  <span class="pt-0.5"><%= q.question_text %></span>
                </div>
                <%= button_to "×", question_layout_question_path(layout, q), method: :delete, form: { data: { turbo_confirm: "Remove question?" } }, class: "flex h-6 w-6 items-center justify-center rounded-md text-slate-400 hover:bg-rose-100 hover:text-rose-600 cursor-pointer opacity-0 group-hover:opacity-100 transition-all duration-200" %>
              </li>
            <% end %>
          </ul>
        <% else %>
          <div class="rounded-xl border border-dashed border-slate-300 bg-white/50 p-6 text-center">
            <p class="text-sm font-medium italic text-slate-500">No questions added yet.</p>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

</div>
