#!/usr/bin/env sh

# Exit immediately if a command exits with a non-zero status
set -e
# Automatically load local .env variables if the file exists
if [ -f .env ]; then
  export $(cat .env | grep -v '^#' | xargs)
fi
# Set environment to production
export RAILS_ENV="production"

# Set APP_HOST automatically from Tailscale if not already set
if [ -z "$APP_HOST" ]; then
  # 1. Locate Tailscale binary in standard paths
  TS_BIN=""
  for path in tailscale /usr/bin/tailscale /usr/sbin/tailscale /opt/homebrew/bin/tailscale; do
    if command -v "$path" >/dev/null 2>&1; then
      TS_BIN="$path"
      break
    fi
  done

  # 2. Try official Tailscale CLI first (handles node renames/aliases)
  if [ -n "$TS_BIN" ]; then
    TS_DNS=$("$TS_BIN" status --json 2>/dev/null | grep -o '"DNSName":"[^"]*"' | head -n1 | cut -d'"' -f4 | sed 's/\.$//')
    if [ -n "$TS_DNS" ]; then
      export APP_HOST="$TS_DNS"
      echo "\n=== Auto-detected Tailscale Host (via CLI): $APP_HOST ==="
    fi
  fi

  # 3. Fallback to local hostname + resolv.conf search domain if CLI failed/missing
  if [ -z "$APP_HOST" ] && [ -f /etc/resolv.conf ]; then
    TS_SEARCH=$(awk '/^search / {print $2}' /etc/resolv.conf | grep -E '\.ts\.net$' | head -n1)
    if [ -n "$TS_SEARCH" ]; then
      TS_HOST=$(hostname -s 2>/dev/null || hostname 2>/dev/null)

      # Map the system hostname to your Tailscale alias sprs
      if [ "$TS_HOST" = "jax-bigblackcumputer" ] || [ "$TS_HOST" = "jax-bigblackcomputer" ]; then
        TS_HOST="sprs"
      fi

      if [ -n "$TS_HOST" ]; then
        export APP_HOST="${TS_HOST}.${TS_SEARCH}"
        echo "\n=== Auto-detected Tailscale Host (via Resolv): $APP_HOST ==="
      fi
    fi
  fi
fi

echo "\n=== [1/5] Checking Gem Dependencies ==="
bundle check || bundle install

echo "\n=== [2/5] Cleaning Stale Assets ==="
bundle exec rails assets:clobber

echo "\n=== [3/5] Compiling Tailwind & Precompiling Assets ==="
bundle exec rails tailwindcss:build
bundle exec rails assets:precompile

echo "\n=== [4/5] Running Database Migrations ==="
bundle exec rails db:migrate

echo "\n=== [5/5] Starting Production Rails Server on port ${PORT:-3000} ==="
exec bundle exec rails server -b 0.0.0.0 -p ${PORT:-3000}
