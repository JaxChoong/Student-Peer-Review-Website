#!/usr/bin/env sh

# Exit immediately if a command exits with a non-zero status
set -e

# Set environment to production
export RAILS_ENV="production"

echo "\n=== [1/5] Checking Gem Dependencies ==="
bundle check || bundle install

echo "\n=== [2/5] Cleaning Stale Assets ==="
bundle exec rails assets:clobber

echo "\n=== [3/5] Compiling Tailwind & Precompiling Assets ==="
bundle exec rails tailwindcss:build
bundle exec rails assets:precompile

echo "\n=== [4/5] Running Database Migrations ==="
bundle exec rails db:migrate

echo "\n=== [5/5] Starting Production Rails Server on port ${PORT:-3000} ==="
exec bundle exec rails server -b 0.0.0.0 -p ${PORT:-3000}
